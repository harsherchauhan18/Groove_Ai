# ============================================================
# groove-ai — WORKER .env.example  (Celery)
# Copy this file to .env and fill in the real values.
# ============================================================

# ── Celery broker / backend ──────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── FastAPI engine (to call back into the engine) ────────────
FASTAPI_URL=http://localhost:8000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/grooveai

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
