# ============================================================
# groove-ai — ROOT .env.example
# Copy this file to .env and fill in the real values.
# ============================================================

# ── Node API ────────────────────────────────────────────────
NODE_API_PORT=5000
NODE_ENV=development

# ── FastAPI Engine ──────────────────────────────────────────
FASTAPI_HOST=http://localhost
FASTAPI_PORT=8000

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=grooveai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Neo4j ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Client ──────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Gemini / Grok / Ollama ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro
GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-1
OLLAMA_BASE_URL=http://localhost:11434

# ── Worker (Celery) ─────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REPOS_BASE_DIR=./data/repos
FAISS_INDEX_PATH=./data/faiss_index

# ── Internal Service URLs ───────────────────────────────────
WORKER_REDIS_URL=redis://localhost:6379/0
FASTAPI_INTERNAL_URL=http://localhost:8000
