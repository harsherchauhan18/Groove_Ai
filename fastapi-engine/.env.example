# ============================================================
# groove-ai — FASTAPI-ENGINE .env.example
# Copy this file to .env and fill in the real values.
# ============================================================

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_postgres_password@localhost:5432/grooveai

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── JWT (shared secret with node-api for token validation) ──
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ── Gemini (Google) ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro

# ── Grok (xAI) ──────────────────────────────────────────────
GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-1

# ── Ollama (local LLM fallback) ──────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── FAISS index storage path ─────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index

# ── Repos clone base directory ───────────────────────────────
REPOS_BASE_DIR=./data/repos

# ── CORS allowed origins ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
